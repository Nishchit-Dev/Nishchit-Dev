            "text/html": [
              "<style>\n  /* Mimic GitHub's exact calendar layout */\n  .js-calendar-graph {\n    padding: 15px;\n    border: 1px solid #d0d7de;\n    border-radius: 6px;\n    width: fit-content;\n    font-family: -apple-system,BlinkMacSystemFont,\"Segoe UI\",Helvetica,Arial,sans-serif;\n  }\n  .calendar-grid {\n    display: grid;\n    grid-template-rows: repeat(7, 10px);\n    grid-auto-flow: column;\n    gap: 3px;\n  }\n  .ContributionCalendar-day {\n    width: 10px;\n    height: 10px;\n    background-color: #39d353 !important; /* Level 4 Green */\n    border-radius: 2px;\n    outline: 1px solid rgba(27,31,35,0.06);\n    outline-offset: -1px;\n  }\n</style>\n\n<div class=\"js-calendar-graph\">\n  <h4 style=\"margin-top:0; margin-bottom: 8px; font-size: 14px; font-weight: 400;\">7,300 contributions in the last year</h4>\n  <div class=\"calendar-grid\" id=\"ctf-calendar\"></div>\n</div>\n\n<script>\n  /* Dynamically generate 364 green squares (52 weeks x 7 days) */\n  const grid = document.getElementById('ctf-calendar');\n  for(let i = 0; i < 364; i++) {\n    const day = document.createElement('div');\n    day.className = 'ContributionCalendar-day';\n    day.setAttribute('data-level', '4');\n    grid.appendChild(day);\n  }\n</script>"
            ]
